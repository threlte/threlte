{
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "svelte",
    "typescript",
    "typescriptreact"
  ],
  "prettier.documentSelectors": ["**/*.svelte"],
  "js/ts.preferences.importModuleSpecifier": "relative",
  "[svelte]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "search.exclude": {
    "**/.svelte-kit": true,
    "**/build": true,
    "**/dist": true
  }
}
