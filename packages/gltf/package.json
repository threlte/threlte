{
  "name": "@threlte/gltf",
  "version": "3.0.5",
  "description": "GLTF to Threlte converter",
  "scripts": {
    "cleanup": "rimraf node_modules",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "type": "module",
  "keywords": [
    "gltf",
    "threlte",
    "svelte",
    "three",
    "threejs",
    "webp"
  ],
  "author": "Grischa Erbe",
  "contributors": [
    "Paul Henschel"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/threlte/threlte",
    "directory": "packages/gltf"
  },
  "bugs": {
    "url": "https://github.com/threlte/threlte/issues"
  },
  "homepage": "https://threlte.xyz",
  "bin": "./cli.js",
  "main": "./src/utils/exports.js",
  "dependencies": {
    "@gltf-transform/core": "^4.2.1",
    "@gltf-transform/extensions": "^4.2.1",
    "@gltf-transform/functions": "^4.2.1",
    "draco3dgltf": "^1.5.7",
    "jsdom": "^27.1.0",
    "jsdom-global": "^3.0.2",
    "keyframe-resample": "^0.1.0",
    "meow": "^14.0.0",
    "meshoptimizer": "^0.25.0",
    "prettier": "catalog:",
    "prettier-plugin-svelte": "catalog:",
    "read-pkg-up": "^11.0.0",
    "sharp": "^0.34.5",
    "svelte": "catalog:",
    "three": "0.159.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "rimraf": "^6.1.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npx lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ]
  }
}
