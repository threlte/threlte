---
import '$styles/app.css'
import '$styles/code.css'
import '$styles/markdown.css'
import SEO from '$components/SEO/SEO.astro'

export interface Props {
  title: string
  description?: string
  image?: string
  canonical?: string
  type?: 'website' | 'article'
  noindex?: boolean
  article?: {
    publishedTime?: string
    modifiedTime?: string
    author?: string
  }
}

const { title, description, image, canonical, type, noindex, article } = Astro.props
---

<!doctype html>
<html
  lang="en"
  class="bg-[#0A0F19]"
>
  <head>
    <script is:inline define:vars={{ base: import.meta.env.BASE_URL }}>
      if (base !== '/' && 'serviceWorker' in navigator) {
        navigator.serviceWorker
          .register(base + 'sw-base-rewrite.js', { scope: base })
          .then((reg) => {
            // On first visit the SW isn't active yet — reload once it takes control
            // so all asset requests go through the rewriter
            if (!navigator.serviceWorker.controller) {
              navigator.serviceWorker.addEventListener(
                'controllerchange',
                () => {
                  window.location.reload()
                },
                { once: true }
              )
            }
          })
      }
    </script>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <SEO
      {title}
      {description}
      {image}
      {canonical}
      {type}
      {noindex}
      {article}
    />

    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900"
      rel="stylesheet"
    />

    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href={`${import.meta.env.BASE_URL}icons/apple-touch-icon.png`}
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href={`${import.meta.env.BASE_URL}icons/favicon-32x32.png`}
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href={`${import.meta.env.BASE_URL}icons/favicon-16x16.png`}
    />
    <link
      rel="manifest"
      href={`${import.meta.env.BASE_URL}icons/site.webmanifest`}
    />
    <link
      rel="mask-icon"
      href={`${import.meta.env.BASE_URL}icons/safari-pinned-tab.svg`}
      color="#fe3d00"
    />
    <link
      rel="shortcut icon"
      href={`${import.meta.env.BASE_URL}icons/favicon.ico`}
    />
    <meta
      name="msapplication-TileColor"
      content="#2b5797"
    />
    <meta
      name="msapplication-config"
      content={`${import.meta.env.BASE_URL}icons/browserconfig.xml`}
    />
    <meta
      name="theme-color"
      content="#0a0F19"
    />

    <slot name="head" />
  </head>
  <body
    transition:animate="initial"
    class="relative bg-[#0A0F19] font-sans text-white"
  >
    <slot />
  </body>
</html>
